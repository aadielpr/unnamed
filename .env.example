# API server
PORT=8080

# Database
# Docker path uses port 5433 (mapped in docker-compose.yml).
# Native Postgres users: change the port to 5432 (or your own) and set the
# user/password/db to match your local install.
POSTGRES_USER=eventlens
POSTGRES_PASSWORD=eventlens
POSTGRES_DB=eventlens
DATABASE_URL=postgres://eventlens:eventlens@localhost:5433/eventlens?sslmode=disable

# S3-compatible object storage (MinIO for local dev, R2 for production).
# Docker path points at http://localhost:9000 (mapped in docker-compose.yml).
# Native MinIO users: point STORAGE_ENDPOINT at your local MinIO server, or
# at R2 in production, and set the access keys accordingly.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=eventlens
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_USE_PATH_STYLE=true

# Directory containing the built SPA static assets.
STATIC_DIR=web/dist
